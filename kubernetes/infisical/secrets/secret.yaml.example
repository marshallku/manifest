# Plain template — DO NOT commit real values.
#
# 1) Generate strong values:
#    ENCRYPTION_KEY:    openssl rand -hex 16
#    AUTH_SECRET:       openssl rand -base64 32
#    POSTGRES_PASSWORD: openssl rand -base64 24
#
# 2) Replace placeholders below, then seal:
#    kubeseal \
#      --controller-namespace kube-system \
#      --controller-name sealed-secrets \
#      --format yaml < secret.yaml > sealed-secret.yaml
#
# 3) Commit only sealed-secret.yaml.
apiVersion: v1
kind: Secret
metadata:
  name: infisical-secret
  namespace: infisical
type: Opaque
stringData:
  ENCRYPTION_KEY: "REPLACE_16_BYTE_HEX"
  AUTH_SECRET: "REPLACE_32_BYTE_BASE64"
  POSTGRES_PASSWORD: "REPLACE_PG_PASSWORD"
  DB_CONNECTION_URI: "postgres://infisical:REPLACE_PG_PASSWORD@infisical-postgres.infisical.svc.cluster.local:5432/infisical?sslmode=disable"
