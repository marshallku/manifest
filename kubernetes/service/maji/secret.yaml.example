apiVersion: v1
kind: Secret
metadata:
  name: maji-secret
  namespace: maji
type: Opaque
stringData:
  DATABASE_URL: "postgres://user:password@db.example.com:5432/maji?sslmode=disable"
  JWT_SECRET: "change-me"
  KAKAO_CLIENT_ID: ""
  KAKAO_CLIENT_SECRET: ""
  GOOGLE_CLIENT_ID: ""
  GOOGLE_CLIENT_SECRET: ""
  S3_ACCESS_KEY_ID: ""
  S3_SECRET_ACCESS_KEY: ""
