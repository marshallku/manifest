# Register personality-web with ArgoCD (run once, manually — Application CRs
# are not synced from this repo). `.example` so the personality-web Application
# itself doesn't try to apply this file (it ignores *.yaml.example by extension).
#
#   kubectl apply -f kubernetes/service/irang-dev/personality/argocd-application.yaml.example
#
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: personality-web-dev
  namespace: argocd
spec:
  project: miniapp
  source:
    repoURL: https://github.com/marshallku/manifest.git
    targetRevision: HEAD
    path: kubernetes/service/irang-dev/personality
  destination:
    server: https://kubernetes.default.svc
    namespace: irang-dev
  syncPolicy:
    automated: { prune: true, selfHeal: true }
